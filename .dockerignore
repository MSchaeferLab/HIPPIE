# Version control
.git
.gitignore

# Python
__pycache__/
*.py[codz]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
npm-debug.log

# Local databases / build artefacts
*.sqlite3
hippie_django/db.sqlite3
hippie_django/staticfiles/
hippie_django/media/
staticfiles/

# Ignore large reference data files (bind-mounted at runtime, not baked into image)
hippie_django/data/*
!hippie_django/data/download_update_data.sh
hippie_django/logs/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Docs / misc
README.md
.env
.env.*
!.env.example
docker-compose.override.yml
