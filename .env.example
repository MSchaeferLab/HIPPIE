# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-please
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080

# ── Analytics ───────────────────────────────────────────────────────────────
# GA4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable analytics.
DJANGO_GA_MEASUREMENT_ID=

# ── Database (MariaDB) ──────────────────────────────────────────────────────
# These point at the MariaDB running on the HOST machine (not a container).
# MARIADB_* are the database name + credentials of that existing host DB.
# DB_HOST=host.docker.internal lets containers reach the host's MariaDB.
# The host MariaDB must listen on the docker-gateway interface (bind-address
# 172.17.0.1) and grant the user from the container network (e.g. 'hippie'@'%').
DATABASE_ENGINE=mariadb
MARIADB_DATABASE=hippie
MARIADB_USER=hippie
MARIADB_PASSWORD=hippie
DB_HOST=host.docker.internal
DB_PORT=3306

# ── Celery / Redis ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Django cache (browse row-count memoisation) — separate Redis DB index from Celery.
REDIS_CACHE_URL=redis://redis:6379/1

# ── Apache ──────────────────────────────────────────────────────────────────
# Host port to expose Apache on.
HOST_PORT=8080
# URL path prefix the app is served under (leave empty for root deployment,
# e.g. set to "/hippie" if the app lives at https://example.com/hippie/).
APACHE_PUBLISHED_PATH=

# Override individually only if your paths differ from APACHE_PUBLISHED_PATH:
DJANGO_SCRIPT_NAME=
DJANGO_STATIC_URL=
